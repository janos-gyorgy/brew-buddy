# Backend (server/) environment
DATABASE_URL="postgresql://user:pass@localhost:5432/brewbuddy"
PORT="3000"

# Secret used to sign session cookies (JWT). Required when NODE_ENV=production.
SESSION_SECRET=""

# Shared invite code new users must enter to register. Leave empty to close
# registration entirely.
INVITE_CODE=""

# Set to "production" in deployed environments (marks cookies Secure).
# NODE_ENV="production"

# One-off owner seed (see server/src/seed-owner.ts) — adopts pre-existing
# single-user data into this account. Never commit real values.
# OWNER_USERNAME="hippotion"
# OWNER_PASSWORD=""
